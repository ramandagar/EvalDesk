# ──────────────────────────────────────────────────────────────────
# EvalDesk environment variables.
# Copy to `.env` (next to docker-compose.yml) and fill in real values.
# EvalDesk FAILS CLOSED if encryption is unset — do not skip it.
# ──────────────────────────────────────────────────────────────────

# ── Database ───────────────────────────────────────────────────────
# Production = Postgres. (For quick local/dev only, set DB_DRIVER=sqlite
# and DATABASE_URL=./data/evaldesk.db.)
DB_DRIVER=postgres
POSTGRES_USER=evaldesk
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_string
POSTGRES_DB=evaldesk
# Used by the app to connect (matches the db service in docker-compose):
DATABASE_URL=postgres://evaldesk:CHANGE_ME_to_a_long_random_string@db:5432/evaldesk

# ── Encryption (REQUIRED) ──────────────────────────────────────────
# Envelope-encryption keyring for secrets (agent keys, signing keys).
# Generate with:  openssl rand -base64 32
EVALDESK_ENCRYPTION_KEYS=dev1:PASTE_BASE64_32_BYTE_KEY_HERE
EVALDESK_ACTIVE_KEY_ID=dev1

# ── AI Judge — bring your own key (pick ONE provider) ─────────────
JUDGE_PROVIDER=deepseek          # deepseek | openai | openrouter | ollama
JUDGE_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-...          # your DeepSeek key
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=production
# Optional worker tuning:
# WORKER_INTERVAL_MS=2000
# Set to 1 ONLY if you run the worker as a separate process (npm run worker):
# EVALDESK_DISABLE_WORKER=0

# ── Email (optional — defaults to console logging) ────────────────
# In self-host, the password-reset link is logged to stdout if SMTP is unset.
# EVALDESK_SMTP_URL=smtps://user:pass@smtp.example.com:465
# EVALDESK_EMAIL_FROM=EvalDesk <noreply@yourdomain.com>
