# EvalDesk Environment Variables
# Copy this file to .env.local and fill in the values

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# Database
DATABASE_URL=./data/evaldesk.db

# Optional: For LLM-as-Judge feature
OPENAI_API_KEY=

# Optional: For email magic link auth
SMTP_SERVER=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@evaldesk.dev
